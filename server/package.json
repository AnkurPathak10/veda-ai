{
  "name": "vedaai-server",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "dotenv -e ../.env -- prisma generate && tsc",
    "start": "node dist/index.js",
    "db:generate": "dotenv -e ../.env -- prisma generate",
    "db:push": "dotenv -e ../.env -- prisma db push",
    "db:studio": "dotenv -e ../.env -- prisma studio"
  },
  "type": "module",
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bullmq": "^5.77.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "socket.io": "^4.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.1",
    "dotenv-cli": "^11.0.0",
    "prisma": "^6.19.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
