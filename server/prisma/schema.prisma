generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URI")
}

// Synced from Clerk on first sign-in or via webhook
model User {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  clerkId        String   @unique
  email          String?
  firstName      String?
  lastName       String?
  imageUrl       String?
  schoolName     String?
  schoolLocation String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  assignments       Assignment[]
  notifications     Notification[]
  groupMembers      GroupMember[]
  groupsCreated     Group[]            @relation("GroupCreator")
  sharedAssignments SharedAssignment[]
  libraryItems      LibraryItem[]
}

model Assignment {
  id             String           @id @default(auto()) @map("_id") @db.ObjectId
  title          String
  description    String?
  dueDate        String?
  additionalInfo String?
  uploadedFile   Json?
  questionRows   Json?
  status         AssignmentStatus @default(ACTIVE)
  userId         String           @db.ObjectId
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  questionPapers    QuestionPaper[]
  sharedInGroups    SharedAssignment[]
}

model QuestionPaper {
  id           String              @id @default(auto()) @map("_id") @db.ObjectId
  assignmentId String              @db.ObjectId
  assignment   Assignment          @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  prompt       String?
  content      String?
  status       QuestionPaperStatus @default(PENDING)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model Notification {
  id        String           @id @default(auto()) @map("_id") @db.ObjectId
  userId    String           @db.ObjectId
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType @default(INFO)
  title     String
  message   String
  href      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
}

model Group {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  createdById String   @db.ObjectId
  createdBy   User     @relation("GroupCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members           GroupMember[]
  sharedAssignments SharedAssignment[]
}

model GroupMember {
  id       String          @id @default(auto()) @map("_id") @db.ObjectId
  groupId  String          @db.ObjectId
  group    Group           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId   String          @db.ObjectId
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     GroupMemberRole @default(MEMBER)
  joinedAt DateTime        @default(now())
}

model SharedAssignment {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  groupId      String     @db.ObjectId
  group        Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  assignmentId String     @db.ObjectId
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  sharedById   String     @db.ObjectId
  sharedBy     User       @relation(fields: [sharedById], references: [id], onDelete: Cascade)
  sharedAt     DateTime   @default(now())
}

enum AssignmentStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum QuestionPaperStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
}

enum NotificationType {
  SUCCESS
  ERROR
  INFO
}

enum GroupMemberRole {
  OWNER
  MEMBER
}

enum LibraryItemType {
  LESSON_PLAN
  WORKSHEET
  DIFFERENTIATED_PAPERS
  CHAPTER_SUMMARY
}

model LibraryItem {
  id        String          @id @default(auto()) @map("_id") @db.ObjectId
  userId    String          @db.ObjectId
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tool      LibraryItemType
  title     String
  content   Json
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}
